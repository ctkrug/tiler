{
  "name": "tiler",
  "version": "0.1.0",
  "private": true,
  "description": "Drag windows onto a canvas and watch four tiling-window-manager algorithms reflow them live, side by side.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ctkrug/tiler.git"
  },
  "homepage": "https://github.com/ctkrug/tiler#readme",
  "bugs": "https://github.com/ctkrug/tiler/issues",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.9.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
